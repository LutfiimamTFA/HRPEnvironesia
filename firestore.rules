

/**
 * This ruleset enforces a strict security model for the HRP Starter application,
 * balancing user ownership with powerful administrative capabilities.
 *
 * Core Philosophy:
 * The security model is based on user ownership, where users have primary control
 * over their own data. This is augmented by a global 'super_admin' role, which
 * has universal access to all data for administrative purposes.
 *
 * Key Security Decisions:
 * - Default Deny: All access is denied by default. Rules explicitly grant permissions.
 * - List vs. Get: Rules for 'list' (queries) must be broad and cannot depend on
 *   document content or cross-document 'get' calls. Rules for 'get' (single doc)
 *   are more specific and are checked after the query runs.
 * - Performant Admin Checks: The super_admin role is checked using exists(),
 *   which is much faster and more scalable than reading a user's profile document.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /**
     * Checks if a user is authenticated. Safe for all queries.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user is the owner of a document
     * by comparing their UID to the document's ID in the path. Safe for all queries.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the user is a 'super_admin'.
     * Checks (in order, any match wins):
     *  - fixed super-admin email (bootstrap account, always trusted)
     *  - existence check on roles_admin/{uid} (fast, safe for list queries)
     *  - users/{uid}.role == 'super-admin' (hyphen — canonical value used across the app)
     *  - users/{uid}.role == 'super_admin' (underscore — legacy/alternate value seen in some docs)
     */
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'super_admin@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'
      );
    }
    
    /**
     * Checks if the user's role is 'hrd' via a performant existence check.
     * HRD access is active only when roles_hrd/{uid}.active is not false.
     */
    function getHrdRole(uid) {
      return get(/databases/$(database)/documents/roles_hrd/$(uid)).data;
    }

    function isHrd() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/roles_hrd/$(request.auth.uid)) &&
        getHrdRole(request.auth.uid).get('active', true) != false;
    }

    function hrdScopeType() {
      return getHrdRole(request.auth.uid).get('scopeType', 'selected_companies');
    }

    function hrdAllowedBrandIds() {
      let ids = getHrdRole(request.auth.uid).get('allowedBrandIds', []);
      return ids is list ? ids : [];
    }

    function isHrdAllCompanies() {
      return isHrd() && hrdScopeType() == 'all_companies';
    }

    function isHrdAllowedForBrand(brandId) {
      return isHrd() &&
        brandId is string &&
        (isHrdAllCompanies() || brandId in hrdAllowedBrandIds());
    }

    function hrdCanReadBrandData(data) {
      return isHrdAllowedForBrand(data.get('brandId', null));
    }

    // leave_requests has accumulated several different "this is the owning
    // employee" field names across older and newer writes (employeeId was
    // the original field; employeeUid/requesterUid/uid were added later for
    // clients that expect one of those specific names) — check all of them
    // so neither an old doc nor a client using a different field name gets
    // incorrectly denied.
    function isLeaveRequestOwner(data) {
      return data.get('employeeUid', '') == request.auth.uid ||
        data.get('requesterUid', '') == request.auth.uid ||
        data.get('uid', '') == request.auth.uid ||
        data.get('userId', '') == request.auth.uid ||
        // employeeId compatibility fallback only — old documents stored the
        // auth UID here before employeeUid existed. New writes should use
        // employeeId for an internal employee code instead, not the UID.
        data.get('employeeId', '') == request.auth.uid;
    }

    // attendance_sites stores brandIds as an array (a site can serve multiple
    // brands) rather than the singular brandId most other collections use —
    // this variant supports both so HRD access actually works for that
    // collection without touching hrdCanReadBrandData (shared by many others).
    function isHrdAllowedForAnyBrand(brandIds) {
      return isHrd() &&
        brandIds is list &&
        (isHrdAllCompanies() || brandIds.hasAny(hrdAllowedBrandIds()));
    }

    function hrdCanAccessSiteData(data) {
      let brandIds = data.get('brandIds', null);
      return brandIds is list
        ? isHrdAllowedForAnyBrand(brandIds)
        : isHrdAllowedForBrand(data.get('brandId', null));
    }

    function hrdCanCreateBrandData(data) {
      return hrdCanReadBrandData(data);
    }

    function hrdCanUpdateBrandData(currentData, nextData) {
      return hrdCanReadBrandData(currentData) && hrdCanReadBrandData(nextData);
    }

    function isHrdVisibleUserData(data) {
      return data.get('role', '') in ['manager', 'karyawan'];
    }

    function hrdCanReadApplication(appData) {
      return hrdCanReadBrandData(appData);
    }

    function hrdCanReadOffering(offeringData) {
      let appId = offeringData.get('applicationId', null);
      return hrdCanReadBrandData(offeringData) ||
        (appId is string && hrdCanReadApplication(get(/databases/$(database)/documents/applications/$(appId)).data));
    }

    function hrdCanReadAssessmentSession(sessionData) {
      let appId = sessionData.get('applicationId', null);
      return hrdCanReadBrandData(sessionData) ||
        (appId is string && hrdCanReadApplication(get(/databases/$(database)/documents/applications/$(appId)).data));
    }

    function hrdCanReadMission(missionId) {
      return hrdCanReadBrandData(get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data);
    }

    function hrdCanReadLegacyTrip(tripId) {
      return hrdCanReadBrandData(get(/databases/$(database)/documents/business_trips/$(tripId)).data);
    }

    /**
     * Inventory Admin — a separate access grant (inventory_access/{uid}.status
     * == 'active'), NOT an HRP role. Super Admin always has full inventory
     * access on top of this (see canManageInventory below); grant/revoke of
     * this flag itself is Super-Admin-only (see /inventory_access rules).
     */
    function isInventoryAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/inventory_access/$(request.auth.uid)).data.status == 'active'
      );
    }

    /** Super Admin or Inventory Admin — for future inventory data collections (items, borrowings, etc). */
    function canManageInventory() {
      return isSuperAdmin() || isInventoryAdmin();
    }

    /**
     * WARNING: NOT SAFE FOR LIST QUERIES.
     * Gets the full user document. Use only in 'get' or 'write' rules.
     * Using this in a 'list' rule will cause the query to be denied.
     */
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getCurrentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isManagement() {
      let user = getCurrentUserData();
      return isSignedIn() && (
        user.role in ['super-admin', 'hrd', 'management', 'manager', 'director', 'direktur'] ||
        user.structuralLevel in ['director', 'management'] ||
        user.structuralPosition in ['director', 'management', 'division_manager'] ||
        user.position in ['Director Of Operational Environesia', 'Director Of Business Development Environesia', 'Director'] ||
        user.jobTitle in ['Director Of Operational Environesia', 'Director Of Business Development Environesia', 'Director']
      );
    }
    
    /**
     * WARNING: NOT SAFE FOR LIST QUERIES.
     * Checks if the user has an internal role (e.g., employee, manager).
     */
    function isInternal() {
      let role = getUserData().role;
      return role in ['super-admin', 'hrd', 'manager', 'karyawan'];
    }

    /**
     * Checks if the user has a 'kandidat' role.
     * WARNING: NOT SAFE FOR LIST QUERIES.
     */
    function isCandidate() {
      return isSignedIn() && getUserData().role == 'kandidat';
    }

    /**
     * Validates incoming data on create to enforce UID integrity.
     */
    function hasValidCreateData(userId) {
      return request.resource.data.uid == userId;
    }

    /**
     * Validates incoming data on update to prevent UID mutation.
     */
    function hasValidUpdateData() {
      return request.resource.data.uid == resource.data.uid;
    }

    /**
     * WARNING: NOT SAFE FOR LIST QUERIES.
     * Checks if the requesting user is the supervisor of the given intern.
     */
    function isSupervisor(internUid) {
      let employeeProfile = get(/databases/$(database)/documents/employee_profiles/$(internUid)).data;
      return employeeProfile.supervisorUid == request.auth.uid;
    }
    
    /**
     * WARNING: NOT SAFE FOR LIST QUERIES.
     * Checks if the requesting user is the assigned division manager for a specific submission.
     */
    function isAssignedManager(submission) {
      let managerData = getUserData();
      return managerData.isDivisionManager == true && 
             managerData.managedDivision == submission.division &&
             managerData.managedBrandId == submission.brandId;
    }


    // --- Collection Rules ---

    /**
     * /users/{userId}
     * - A user can get/update their own document.
     * - Only a super_admin can list all users or create/delete them.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) ||
        isSuperAdmin() ||
        (isHrd() && isHrdVisibleUserData(resource.data) && hrdCanReadBrandData(resource.data)) ||
        (isInternal() && !isHrd());
      allow update: if isOwner(userId) ||
        isSuperAdmin() ||
        (
          isHrd() &&
          isHrdVisibleUserData(resource.data) &&
          isHrdVisibleUserData(request.resource.data) &&
          hrdCanUpdateBrandData(resource.data, request.resource.data) &&
          request.resource.data.role == resource.data.role
        );
      allow list: if isSuperAdmin() ||
        (isHrd() && isHrdVisibleUserData(resource.data) && hrdCanReadBrandData(resource.data));
      allow create: if (isOwner(userId) && request.resource.data.role == 'kandidat' && hasValidCreateData(userId)) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      match /saved_jobs/{jobId} {
        allow read, write, delete: if isOwner(userId);
      }

      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if isSuperAdmin() || isHrd();
      }
    }

    /**
     * /profiles/{userId} (Candidate Profile)
     * - A candidate can read and write to their own profile.
     * - Internal users can read any single profile for review purposes.
     */
    match /profiles/{userId} {
      allow get: if isOwner(userId) || isInternal();
      allow write: if isOwner(userId);
    }

    /**
     * /candidate_personality_tests/{candidateUid}
     * - Candidates can read and maintain their own global personality test status.
     * - Internal users can read/list for recruitment review and backfill.
     * - Only HRD and Super Admin can delete.
     */
    match /candidate_personality_tests/{candidateUid} {
      allow get: if isOwner(candidateUid) || isInternal() || isHrd() || isSuperAdmin();
      allow list: if isInternal() || isHrd() || isSuperAdmin();
      allow create, update: if isOwner(candidateUid) || isInternal() || isHrd() || isSuperAdmin();
      allow delete: if isHrd() || isSuperAdmin();
    }

    /**
     * /employee_profiles/{uid} (Intern/Employee Profile)
     * - An employee can read/write their own profile.
     * - Internal users (hrd, super_admin, managers, other employees) can view any profile.
     * - This broad read access for internal users is necessary to allow supervisors
     *   to check their interns' profiles without causing security rule deadlocks.
     */
    match /employee_profiles/{uid} {
        function isUpdatingOwnAllowedFields() {
          let allowedFields = [
            'uid', 'dataDiriIdentitas', 'alamat', 'dokumenAdministratif',
            'dataRekening', 'dataKeluarga', 'kontakDarurat', 'updatedAt', 'completeness',
            'verificationStatus', 'verificationNotes', 'verificationUpdatedAt'
          ];
          return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
        }

      allow get: if isOwner(uid) ||
        isSuperAdmin() ||
        (isHrd() && hrdCanReadBrandData(resource.data)) ||
        (isInternal() && !isHrd());
      allow create: if isOwner(uid) || isSuperAdmin() || (isHrd() && hrdCanCreateBrandData(request.resource.data));
      allow update: if (isOwner(uid) && isUpdatingOwnAllowedFields()) ||
        isSuperAdmin() ||
        (isHrd() && hrdCanUpdateBrandData(resource.data, request.resource.data));
      allow list: if isSuperAdmin() || (isHrd() && hrdCanReadBrandData(resource.data));
      allow delete: if false;
    }
    
    /**
     * /roles_admin/{userId}
     * - Lookup table used by isSuperAdmin() for fast existence checks.
     * - A user can read their own doc (to verify their own admin status).
     * - Only super admins (by user doc role) can create/update/delete entries.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin'
      );
      allow list: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin';
      allow create, update, delete: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin';
    }
    
    /**
     * /roles_hrd/{userId}
     * - Lookup table used by isHrd() for fast existence checks.
     * - A user can read their own doc.
     * - Only super admins can manage entries.
     */
    match /roles_hrd/{userId} {
      allow get: if isSignedIn() && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin'
      );
      allow list: if isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    /**
     * /invite_batches/{batchId}
     * - Super Admin: full read/list/create/update/delete on every batch.
     * - HRD: only batches whose brandId is in their own allowedBrandIds —
     *   reused via isHrdAllowedForBrand() (same helper brands/attendance/etc.
     *   already use), so the client MUST query with a
     *   where('brandId','in',allowedBrandIds) filter (chunked ≤10) for list
     *   to succeed — Firestore evaluates `list` rules per matched document,
     *   so an unscoped query that could return another brand's batch is
     *   rejected outright rather than silently filtered.
     */
    match /invite_batches/{batchId} {
      allow get, list: if isSuperAdmin() || isHrdAllowedForBrand(resource.data.brandId);
      allow create: if isSuperAdmin() || isHrdAllowedForBrand(request.resource.data.brandId);
      allow update, delete: if isSuperAdmin() || isHrdAllowedForBrand(resource.data.brandId);
    }
    
    /**
     * /brands/{brandId}
     * - Brands are public for anyone to read.
     * - Only super_admins can manage (create, update, delete) brands.
     * - Subcollections are also managed by super_admins.
     */
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isSuperAdmin();

      match /divisions/{divisionId} {
        allow read: if isInternal();
        allow write: if isSuperAdmin();
      }
    }

    // Payroll Excel templates (uploaded by Super Admin, mapped to brands via
    // brands/{id}.payrollTemplateId / payroll_groups/{id}.payrollTemplateId).
    // HRD never lists this collection — the frontend resolves a brand's
    // template via a single getDoc using the templateId already denormalized
    // onto brands/{id}, so HRD only ever needs `get`, never `list`.
    match /payroll_templates/{templateId} {
      allow get, list, create, update, delete: if isSuperAdmin();
      allow get: if isHrd();
    }

    // Payroll Groups — Super Admin groups several brands under one shared
    // payroll template/sheet (e.g. "ABC Group" = PT ABC + PT ABC 1-3). HRD
    // never reads this collection directly: on save, Super Admin cascades
    // the group's template mapping onto each member brands/{id} doc, and HRD
    // reads that (already-scoped) brand doc instead — see Tahap 2/5 of the
    // Payroll Group spec.
    match /payroll_groups/{groupId} {
      allow get, list, create, update, delete: if isSuperAdmin();
    }
    
    /**
     * /jobs/{jobId}
     * - Anyone can list jobs (for the careers page).
     * - A single job can be read if it's 'published' or if the user is internal.
     * - Only internal users (hrd, super_admin) can write to jobs.
     */
    match /jobs/{jobId} {
      allow list: if resource.data.publishStatus in ["published", "reopened"] ||
        isSuperAdmin() ||
        (isHrd() && hrdCanReadBrandData(resource.data)) ||
        (isInternal() && !isHrd());
      allow get: if resource.data.publishStatus in ["published", "reopened"] ||
        isSuperAdmin() ||
        (isHrd() && hrdCanReadBrandData(resource.data)) ||
        (isInternal() && !isHrd());
      allow create: if isSuperAdmin() || (isHrd() && hrdCanCreateBrandData(request.resource.data));
      allow update: if isSuperAdmin() || (isHrd() && hrdCanUpdateBrandData(resource.data, request.resource.data));
      allow delete: if isSuperAdmin() || (isHrd() && hrdCanReadBrandData(resource.data));
    }

    /**
     * /applications/{applicationId}
     * - Critical fix for candidate view.
     */
    match /applications/{applicationId} {
        // LIST: Allow a query to proceed if the user is logged in.
        // The client-side query MUST contain `where('candidateUid', '==', request.auth.uid)`.
        // Security is then enforced by the `get` rule below, which Firestore
        // runs on each document in the result set.
        allow list: if isSuperAdmin() ||
                     (isHrd() && hrdCanReadApplication(resource.data)) ||
                     resource.data.candidateUid == request.auth.uid ||
                     request.auth.uid in resource.data.get('allPanelistIds', []) ||
                     request.auth.uid in resource.data.get(['internalReviewConfig', 'assignedReviewerUids'], []);

        // GET: Allow if the user is an admin, the document owner, an assigned panelist, or an assigned internal reviewer.
        allow get: if isSuperAdmin() ||
                     (isHrd() && hrdCanReadApplication(resource.data)) ||
                     resource.data.candidateUid == request.auth.uid || 
                     request.auth.uid in resource.data.get('allPanelistIds', []) ||
                     request.auth.uid in resource.data.get(['internalReviewConfig', 'assignedReviewerUids'], []);

        // CREATE: A user can create an application only if they are the owner.
        // Candidates may create a new application directly in the initial assessment stage.
        allow create: if isCreatingOwn() && (request.resource.data.status == "draft" || request.resource.data.status == "submitted" || request.resource.data.status == "tes_kepribadian" || request.resource.data.status == "screening");
        
        // UPDATE: A candidate can update their own DRAFT or mark an active offer as viewed. Internal users can update any. candidateUid cannot be changed.
        allow update: if 
                      (
                        (
                          isSuperAdmin() ||
                          (isHrd() && hrdCanUpdateBrandData(resource.data, request.resource.data)) ||
                          (isInternal() && !isHrd())
                        ) && (
                          isInternalStatusUpdate() || 
                          isUpdatingCvCache()
                        )
                      ) || 
                      (
                        isOwner() && (
                          resource.data.status == "draft" ||
                          isDecidingOffer() ||
                          isViewingOffer() ||
                          isSubmittingDocuments() ||
                          isUpdatingSubmittedDocuments() ||
                          isRequestingReschedule()
                        )
                      );

        // DELETE: Only internal users can delete applications.
        allow delete: if isSuperAdmin() ||
          (isHrd() && hrdCanReadApplication(resource.data)) ||
          (isInternal() && !isHrd());

        // Helper functions local to this scope for clarity
        function isOwner() {
            return request.auth.uid == resource.data.candidateUid;
        }
        function isCreatingOwn() {
            return request.auth.uid == request.resource.data.candidateUid;
        }
        function isDecidingOffer() {
            let isOwner = request.auth.uid == resource.data.candidateUid;
            let isSentOffer = resource.data.status == 'offered' && resource.data.offerStatus == 'sent';
            let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
            
            let isAccepting = request.resource.data.offerStatus == 'accepted' 
                                && changedKeys.hasOnly(['offerStatus', 'candidateOfferDecisionAt', 'updatedAt']);
                                
            let isRejecting = request.resource.data.offerStatus == 'rejected' 
                                && request.resource.data.status == 'rejected'
                                && changedKeys.hasOnly(['offerStatus', 'candidateOfferDecisionAt', 'updatedAt', 'status']);

            return isOwner && isSentOffer && (isAccepting || isRejecting);
        }
        function isViewingOffer() {
            let isOwner = request.auth.uid == resource.data.candidateUid;
            let isSentOffer = resource.data.status == 'offered' && resource.data.offerStatus == 'sent';
            let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
            return isOwner &&
                   isSentOffer &&
                   request.resource.data.offerStatus == 'viewed' &&
                   changedKeys.hasOnly(['offerStatus', 'offerViewedAt', 'updatedAt']);
        }
        function isSubmittingDocuments() {
            let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
            let allowedKeys = ['cvUrl', 'ijazahUrl', 'cvFileName', 'ijazahFileName', 'status', 'updatedAt'];
            return isOwner()
                && resource.data.status == 'document_submission'
                && request.resource.data.status == 'interview'
                && changedKeys.hasOnly(allowedKeys)
                && request.resource.data.cvUrl is string
                && request.resource.data.ijazahUrl is string;
        }
        function isUpdatingSubmittedDocuments() {
            let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
            let allowedKeys = ['cvUrl', 'ijazahUrl', 'cvFileName', 'ijazahFileName', 'updatedAt'];
            return isOwner()
                && resource.data.status == 'interview'
                && changedKeys.hasOnly(allowedKeys);
        }
        function isUpdatingCvCache() {
            let allowedKeys = ['cvText', 'cvTextExtractedAt', 'cvTextSource', 'cvCharCount'];
            let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
            return isInternal() && changedKeys.hasOnly(allowedKeys);
        }
        function isInternalStatusUpdate() {
            let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
            let allowedKeys = ['status', 'stage', 'stageEnteredAt', 'candidateStatus', 'decisionAt', 'updatedAt', 'personalityTestAssignedAt', 'personalityTestCompleted', 'personalityTestRequired', 'personalityTestStatus', 'personalityTestResultId', 'personalityTestSource', 'personalityTestCompletedAt', 'hrdEvaluationDecision', 'hrdEvaluationDecisionLabel', 'hrdEvaluationDecisionAt', 'hrdEvaluationDecisionBy', 'hrdEvaluationDecisionByName', 'hrdEvaluationDecisionNote', 'cvVerified', 'ijazahVerified', 'timeline', 'interviews', 'allPanelistIds', 'offerStatus', 'offeredSalary', 'probationDurationMonths', 'contractStartDate', 'contractDurationMonths', 'contractEndDate', 'offerNotes', 'offerDescription', 'workDays', 'internalAccessEnabled', 'internalReviewSummary', 'candidateVisibleStatus', 'candidateVisibleMessage', 'candidateVisibleStage', 'candidateVisibleTimeline', 'recruitmentDecisionAt', 'recruitmentDecisionBy', 'recruitmentDecisionByName', 'interviewCompleted', 'interviewCompletedAt', 'interviewCompletionSource', 'postInterviewEvaluation', 'postInterviewDecision', 'internalDecisionLog', 'masterTemplateId', 'offerLetterNumber'];
            let hrdOnlyKeys = ['internalReviewConfig', 'recruitmentInternalDecision'];
            return changedKeys.hasOnly(allowedKeys.concat(hrdOnlyKeys)) &&
                   (!changedKeys.hasAny(hrdOnlyKeys) && isInternal() ||
                    changedKeys.hasAny(hrdOnlyKeys) && (isHrd() || isSuperAdmin()));
        }
        function isRequestingReschedule() {
          let isOwner = request.auth.uid == resource.data.candidateUid;
          let isInterviewStage = resource.data.status == 'interview';
          let allowedKeys = ['interviews', 'timeline', 'updatedAt'];
          let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
          let onlyAllowedFieldsChanged = changedKeys.hasOnly(allowedKeys);
          return isOwner && isInterviewStage && onlyAllowedFieldsChanged;
        }
    }
    
    match /applications/{applicationId}/internal_reviews/{reviewerUid} {
      allow get: if isSuperAdmin() ||
        (isHrd() && hrdCanReadApplication(get(/databases/$(database)/documents/applications/$(applicationId)).data)) ||
        request.auth.uid == reviewerUid ||
        (isSignedIn() && hasInternalReviewAccess(applicationId));
      allow list: if isSuperAdmin() ||
        (isHrd() && hrdCanReadApplication(get(/databases/$(database)/documents/applications/$(applicationId)).data)) ||
        (isSignedIn() && hasInternalReviewAccess(applicationId));
      allow write: if isSuperAdmin() ||
        (isHrd() && hrdCanReadApplication(get(/databases/$(database)/documents/applications/$(applicationId)).data)) ||
        (isOwner(reviewerUid) && hasInternalReviewAccess(applicationId));
    }
    
    match /applications/{applicationId}/post_interview_reviews/{reviewerUid} {
      allow get: if isSuperAdmin() ||
        (isHrd() && hrdCanReadApplication(get(/databases/$(database)/documents/applications/$(applicationId)).data)) ||
        request.auth.uid == reviewerUid ||
        (isSignedIn() && hasPostInterviewReviewAccess(applicationId));
      allow list: if isSuperAdmin() ||
        (isHrd() && hrdCanReadApplication(get(/databases/$(database)/documents/applications/$(applicationId)).data)) ||
        (isSignedIn() && hasPostInterviewReviewAccess(applicationId));
      allow write: if isSuperAdmin() ||
        (isHrd() && hrdCanReadApplication(get(/databases/$(database)/documents/applications/$(applicationId)).data)) ||
        (isOwner(reviewerUid) && hasPostInterviewReviewAccess(applicationId));
    }
    
    function hasInternalReviewAccess(appId) {
      let appData = get(/databases/$(database)/documents/applications/$(appId)).data;
      return request.auth.uid in appData.get(['internalReviewConfig', 'assignedReviewerUids'], []) ||
             request.auth.uid in appData.get('allPanelistIds', []);
    }

    function hasPostInterviewReviewAccess(appId) {
      let appData = get(/databases/$(database)/documents/applications/$(appId)).data;
      // Access granted to explicitly assigned panelists or anyone with general internal review access
      return request.auth.uid in appData.get('allPanelistIds', []) || 
             request.auth.uid in appData.get(['internalReviewConfig', 'assignedReviewerUids'], []) ||
             (isHrd() && hrdCanReadApplication(appData)) || isSuperAdmin();
    }


    /**
     * /navigation_settings/{roleId}
     * - Any signed-in user can read navigation settings to build their UI.
     * - Only super_admins can write/change these settings.
     */
     match /navigation_settings/{roleId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    
    // Web Push device tokens — strictly owner-only (a device token is
    // effectively a personal credential; no HRD/super-admin read access is
    // needed here, unlike most other collections in this file).
    match /push_subscriptions/{uid}/devices/{deviceId} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // --- Monitoring & Attendance Rules ---
    match /attendance_sites/{siteId} {
      allow read: if isSuperAdmin() || (isHrd() && hrdCanAccessSiteData(resource.data));
      allow create: if isSuperAdmin() || (isHrd() && hrdCanAccessSiteData(request.resource.data));
      allow update: if isSuperAdmin() || (isHrd() && hrdCanAccessSiteData(resource.data) && hrdCanAccessSiteData(request.resource.data));
      allow delete: if isSuperAdmin() || (isHrd() && hrdCanAccessSiteData(resource.data));
    }

    match /attendance_events/{eventId} {
      allow read: if isSuperAdmin() || (isHrd() && hrdCanReadBrandData(resource.data));
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSuperAdmin() || (isHrd() && hrdCanReadBrandData(resource.data));
    }

    // Written by the Web Absen app when a staff member submits a "laporan
    // kondisi khusus" (special condition report), including its proof photo
    // fields (conditionProofPhotoUrl/proofPhotoUrl/driveFileId/etc). HRP's
    // Monitoring Absensi reads this collection to render that photo — it must
    // never be confused with attendance_events (tap-in/tap-out) reads above.
    match /attendance_condition_reports/{reportId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;

      allow get: if isSignedIn() && (
        resource.data.uid == request.auth.uid ||
        resource.data.employeeUid == request.auth.uid ||
        isHrd() ||
        isSuperAdmin()
      );

      allow list: if isSignedIn() && (
        isHrd() ||
        isSuperAdmin()
      );

      allow update: if isSignedIn() && (
        isSuperAdmin() ||
        isHrd() ||
        (
          resource.data.uid == request.auth.uid &&
          resource.data.reviewStatus == 'pending'
        )
      );

      allow delete: if isSuperAdmin();
    }

    match /overtime_submissions/{submissionId} {
      function isSubmissionOwner() {
        return request.auth.uid == resource.data.uid;
      }
      function isRequester() {
        return request.auth.uid == request.resource.data.uid;
      }
      
      // Allow read by owner, their manager, HR, or Super Admin
      allow get: if isSignedIn() && (
        isSubmissionOwner() ||
        isAssignedManager(resource.data) ||
        isSuperAdmin() ||
        (isHrd() && hrdCanReadBrandData(resource.data))
      );
      allow list: if isSignedIn() && (
        request.auth.uid == resource.data.uid ||
        isAssignedManager(resource.data) ||
        isSuperAdmin() ||
        (isHrd() && hrdCanReadBrandData(resource.data))
      );

      // Allow create by an internal user for themselves
      allow create: if isInternal() && isRequester();

      // Allow update logic
      allow update: if isSignedIn() && (
        // Owner can update their draft or revision request
        (isSubmissionOwner() && (resource.data.status == 'draft' || resource.data.status.startsWith('revision_'))) ||
        // Manager can act on pending_manager requests
        (isAssignedManager(resource.data) && resource.data.status == 'pending_manager') ||
        // HRD can act on pending_hrd or approved_by_manager requests
        (isHrd() && hrdCanUpdateBrandData(resource.data, request.resource.data) && (resource.data.status == 'pending_hrd' || resource.data.status == 'approved_by_manager')) ||
        // Super Admin can always update
        isSuperAdmin()
      );
      
      allow delete: if isSuperAdmin() || (isSubmissionOwner() && resource.data.status == 'draft');
    }
    
     match /permission_requests/{requestId} {
      function isSubmissionOwner() {
        return request.auth.uid == resource.data.uid;
      }
      function isRequester() {
        return request.auth.uid == request.resource.data.uid;
      }
      
      function isReportingReturn() {
        let isOwner = request.auth.uid == resource.data.uid;
        let isTransitionValid = resource.data.status == 'reported' && request.resource.data.status == 'returned';
        let allowedKeys = [
            'status', 'actualReturnAt', 'returnSource', 'returnDetectedFromAttendance',
            'actualDurationMinutes', 'exceededEstimatedReturn', 'exceededFourHours',
            'overtimeReturnMinutes', 'needsManagerAttention', 'updatedAt'
        ];
        let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
        return isOwner && isTransitionValid && changedKeys.hasOnly(allowedKeys);
      }
      
      allow get: if isSignedIn() && (
        isSubmissionOwner() ||
        isAssignedManager(resource.data) ||
        isSuperAdmin() ||
        (isHrd() && hrdCanReadBrandData(resource.data))
      );
      allow list: if isSignedIn() && (
        request.auth.uid == resource.data.uid ||
        isAssignedManager(resource.data) ||
        isSuperAdmin() ||
        (isHrd() && hrdCanReadBrandData(resource.data))
      );

      allow create: if isInternal() && isRequester();

      allow update: if isSignedIn() && isSubmissionOwner() && (resource.data.status in ['draft', 'revision_manager', 'revision_hrd']);
      allow update: if isSignedIn() && isReportingReturn();
      allow update: if isSignedIn() && isAssignedManager(resource.data) && (resource.data.status in ['pending_manager', 'reported', 'returned']);
      allow update: if isSignedIn() && isHrd() && hrdCanUpdateBrandData(resource.data, request.resource.data) && (resource.data.status in ['pending_hrd', 'approved_by_manager', 'verified_manager']);
      allow update: if isSignedIn() && isSuperAdmin();

      
      allow delete: if isSuperAdmin() || (isSubmissionOwner() && resource.data.status == 'draft');
    }
    
    // --- Assessment Rules ---

    match /assessment_config/{configId} {
      allow get: if isSignedIn();
      allow write: if isInternal() && getUserData().role in ['super-admin', 'hrd'];
    }

    match /assessment_templates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isInternal() && getUserData().role in ['super-admin', 'hrd'];
    }

    match /assessments/{assessmentId} {
      allow get: if isSignedIn() && (resource.data.isActive == true || isInternal());
      allow list: if isSignedIn();
      allow write: if isInternal() && getUserData().role in ['super-admin', 'hrd'];
    }
    
    match /assessment_questions/{questionId} {
      allow list: if isSignedIn(); // Must be relatively open for where-in queries. Client logic is the main guard.
      allow get: if isSignedIn();
      allow write: if isInternal() && getUserData().role in ['super-admin', 'hrd'];
    }
    
    match /assessment_sessions/{sessionId} {
      // READ: A user can get their own session. Internal roles can get any session.
      allow get: if isOwner(resource.data.candidateUid) ||
        isSuperAdmin() ||
        (isHrd() && hrdCanReadAssessmentSession(resource.data)) ||
        (isInternal() && !isHrd());
      
      // LIST: A user can only list their own sessions. Internal roles can list all.
      // This is safe because queries are filtered on the client to check for candidateUid
      allow list: if isSignedIn() && (
        resource.data.candidateUid == request.auth.uid ||
        isSuperAdmin() ||
        (isHrd() && hrdCanReadAssessmentSession(resource.data)) ||
        (isInternal() && !isHrd())
      );

      // CREATE: A user can only create a session for themselves.
      allow create: if isOwner(request.resource.data.candidateUid);
      
      // UPDATE:
      // - A candidate can only update their own session, and only if it's a 'draft'.
      // - Internal roles can update the decision.
      allow update: if (isOwner(resource.data.candidateUid) && resource.data.status == 'draft') ||
        (
          (
            isSuperAdmin() ||
            (isHrd() && hrdCanReadAssessmentSession(resource.data)) ||
            (isInternal() && !isHrd())
          ) &&
          isUpdatingHrdDecision()
        );
                       
      // DELETE: No one can delete a session record.
      allow delete: if false;

      function isUpdatingHrdDecision() {
        let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
        let allowedUpdateKeys = ['hrdDecision', 'hrdDecisionAt', 'hrdDecisionBy', 'updatedAt'];
        
        return isInternal()
          && resource.data.status == 'submitted'
          && changedKeys.hasOnly(allowedUpdateKeys)
          && request.resource.data.hrdDecisionBy == request.auth.uid
          && request.resource.data.hrdDecision in ['pending', 'approved', 'rejected'];
      }
    }

    // --- Intern Daily Report Rules ---
    match /daily_reports/{reportId} {
      allow get: if isSignedIn() && (
                    isOwner(resource.data.uid) ||
                    request.auth.uid == resource.data.supervisorUid ||
                    isSuperAdmin() ||
                    (isHrd() && hrdCanReadBrandData(resource.data))
                  );
                  
      allow list: if isSignedIn() && (
                    resource.data.uid == request.auth.uid ||
                    resource.data.supervisorUid == request.auth.uid ||
                    isSuperAdmin() ||
                    (isHrd() && hrdCanReadBrandData(resource.data))
                  );

      allow create: if isOwner(request.resource.data.uid)
                    && (request.resource.data.status == 'draft' || request.resource.data.status == 'submitted');

      allow update: if isSignedIn() && (
                      (isOwner(resource.data.uid) && resource.data.status in ['draft', 'needs_revision']) ||
                      ((request.auth.uid == resource.data.supervisorUid || isSuperAdmin() || (isHrd() && hrdCanUpdateBrandData(resource.data, request.resource.data))) && resource.data.status == 'submitted')
                    );

      allow delete: if false;
    }
    
    // --- Monthly Evaluation Rules ---
    match /monthly_evaluations/{evaluationId} {
      allow list: if isSuperAdmin() ||
        (isHrd() && hrdCanReadBrandData(resource.data)) ||
        (isSignedIn() && resource.data.internUid == request.auth.uid) ||
        (isSignedIn() && isSupervisor(resource.data.internUid));
      allow get: if isSuperAdmin() ||
        (isHrd() && hrdCanReadBrandData(resource.data)) ||
        (isSignedIn() && evaluationId.split('_')[0] == request.auth.uid) ||
        (isSignedIn() && isSupervisor(evaluationId.split('_')[0]));
      allow create: if isSuperAdmin() ||
        (isHrd() && hrdCanCreateBrandData(request.resource.data)) ||
        (isSignedIn() && isSupervisor(request.resource.data.internUid));
      allow update: if isSuperAdmin() ||
        (isHrd() && hrdCanUpdateBrandData(resource.data, request.resource.data)) ||
        (isSignedIn() && isSupervisor(request.resource.data.internUid));
      allow delete: if isSuperAdmin();
    }

    /**
     * /recruitment_offering_templates/{templateId}
     * - These are the master templates for job offers.
     * - Super Admin and HRD can manage these.
     * - Signed-in recruitment staff (internal) can read active ones.
     */
    match /recruitment_offering_templates/{templateId} {
      allow get, list: if isInternal();
      allow write: if isHrd() || isSuperAdmin() || getUserData().role in ['hrd', 'super-admin'];
    }

    /**
     * /recruitment_offer_description_templates/{templateId}
     * - Reusable HRD offering description templates.
     * - Only internal HRD staff or super admins should read and create them.
     */
    match /recruitment_offer_description_templates/{templateId} {
      allow get, list: if isInternal();
      allow create: if isHrd() || isSuperAdmin();
      allow update, delete: if isHrd() || isSuperAdmin();
    }

    /**
     * /recruitment_offer_description_history/{historyId}
     * - History of past proposal descriptions.
     * - Only internal HRD staff or super admins should read and create them.
     */
    match /recruitment_offer_description_history/{historyId} {
      allow get, list: if isInternal();
      allow create: if isHrd() || isSuperAdmin();
      allow update, delete: if false;
    }

    /**
     * /offerings/{offeringId}
     * - Job offerings sent to candidates via PDF links.
     * - HRD can create, update, read.
     * - Candidates can read their own offerings and update status/interactions.
     */
    match /offerings/{offeringId} {
      allow get: if isSuperAdmin() ||
                    (isHrd() && hrdCanReadOffering(resource.data)) ||
                    (isSignedIn() && (
                      resource.data.get('candidateUid', '') == request.auth.uid || 
                      resource.data.get('candidateEmail', '') == request.auth.token.email ||
                      (resource.data.applicationId != null && get(/databases/$(database)/documents/applications/$(resource.data.applicationId)).data.candidateUid == request.auth.uid)
                    ));
      
      allow list: if isSuperAdmin() ||
                     (isHrd() && hrdCanReadOffering(resource.data)) ||
                     (isSignedIn() && (
                       resource.data.get('candidateUid', '') == request.auth.uid ||
                       resource.data.get('candidateEmail', '') == request.auth.token.email
                     ));

      allow create: if isSuperAdmin() || (isHrd() && hrdCanReadOffering(request.resource.data));

      allow update: if isSuperAdmin() || (isHrd() && hrdCanReadOffering(resource.data) && hrdCanReadOffering(request.resource.data));
      
      allow delete: if false;
    }

    match /leave_requests/{requestId} {
      allow get: if isSignedIn() && (
        isLeaveRequestOwner(resource.data) ||
        resource.data.managerId == request.auth.uid ||
        resource.data.managerUid == request.auth.uid ||
        resource.data.directManagerId == request.auth.uid ||
        resource.data.directManagerUid == request.auth.uid ||
        resource.data.get('approvalTargetUid', '') == request.auth.uid ||
        resource.data.get('directSupervisorUid', '') == request.auth.uid ||
        resource.data.get('currentApproverUid', '') == request.auth.uid ||
        isSuperAdmin() ||
        (isHrd() && hrdCanReadBrandData(resource.data))
      );
      allow list: if isSignedIn() && (
        isLeaveRequestOwner(resource.data) ||
        resource.data.managerId == request.auth.uid ||
        resource.data.managerUid == request.auth.uid ||
        resource.data.directManagerId == request.auth.uid ||
        resource.data.directManagerUid == request.auth.uid ||
        resource.data.get('approvalTargetUid', '') == request.auth.uid ||
        resource.data.get('directSupervisorUid', '') == request.auth.uid ||
        resource.data.get('currentApproverUid', '') == request.auth.uid ||
        isSuperAdmin() ||
        (isHrd() && hrdCanReadBrandData(resource.data))
      );
      allow create: if isSignedIn() && isLeaveRequestOwner(request.resource.data);
      allow update: if isSignedIn() && (
        (isLeaveRequestOwner(resource.data) && (
          resource.data.status in ['pending_manager', 'pending_manager_review', 'pending_director', 'pending_director_review', 'revision_requested', 'revision_requested_by_manager', 'revision_requested_by_hrd'] ||
          request.resource.data.status == 'cancelled'
        )) ||
        ((resource.data.managerId == request.auth.uid ||
          resource.data.managerUid == request.auth.uid ||
          resource.data.directManagerId == request.auth.uid ||
          resource.data.directManagerUid == request.auth.uid ||
          resource.data.get('approvalTargetUid', '') == request.auth.uid ||
          resource.data.get('directSupervisorUid', '') == request.auth.uid ||
          resource.data.get('currentApproverUid', '') == request.auth.uid) && (
            resource.data.status in ['pending_manager', 'pending_manager_review', 'pending_director', 'pending_director_review', 'pending_supervisor', 'menunggu_approval_atasan'] ||
            resource.data.status.startsWith('pending_')
         )) ||
        (isHrd() && hrdCanUpdateBrandData(resource.data, request.resource.data)) ||
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin() || (isLeaveRequestOwner(resource.data) && (
        resource.data.status in ['pending_manager', 'pending_manager_review', 'pending_director', 'pending_director_review'] ||
        resource.data.status.startsWith('pending_')
      ));
    }
    
    // --- Business Trip Missions ---
    match /business_trip_missions/{missionId} {
      // Read mission doc:
      // - super_admin and hrd can read all
      // - creator (assignedByUid) can read
      // - staff who are part of the mission (assignedStaffUids/memberUids) can read
      // - approvers listed in approvalTargetUids can read
      allow get: if isSuperAdmin() || (isHrd() && hrdCanReadBrandData(resource.data)) || (isManagement() && !isHrd()) ||
        (isSignedIn() && (
          resource.data.assignedByUid == request.auth.uid ||
          (resource.data.assignedStaffUids is list && request.auth.uid in resource.data.assignedStaffUids) ||
          (resource.data.memberUids is list && request.auth.uid in resource.data.memberUids) ||
          (resource.data.approvalTargetUids is list && request.auth.uid in resource.data.approvalTargetUids)
        ));

      // Listing missions is restricted to HRD, Super Admin, and Management.
      allow list: if isSuperAdmin() || (isHrd() && hrdCanReadBrandData(resource.data)) || (isManagement() && !isHrd());

      // Creation allowed for signed-in users; assignedByUid must match requester
      allow create: if isSignedIn() && request.resource.data.assignedByUid == request.auth.uid;

      // Update allowed for creator, HRD, or Super Admin
      allow update: if isSuperAdmin() || (isHrd() && hrdCanUpdateBrandData(resource.data, request.resource.data)) || (isSignedIn() && resource.data.assignedByUid == request.auth.uid)
        // Mission members may submit final report (limited fields)
        || (isSignedIn() &&
            (resource.data.memberUids is list && request.auth.uid in resource.data.memberUids ||
             resource.data.assignedStaffUids is list && request.auth.uid in resource.data.assignedStaffUids) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'reportMode', 'finalReportSubmittedAt', 'finalReportSubmittedBy', 'updatedAt'
            ]) &&
            request.resource.data.status == 'final_report_submitted')
        // HRD/management may archive mission (limited fields)
        || (isSignedIn() && isManagement() && !isHrd() &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'archivedAt', 'archivedByUid', 'archivedByName', 'updatedAt'
            ]) &&
            request.resource.data.status == 'completed');

      // Deletion reserved for Super Admin or HRD
      allow delete: if isSuperAdmin() || (isHrd() && hrdCanReadBrandData(resource.data));

      // Members subcollection: individual member docs keyed by employee UID
      match /members/{memberId} {
        // Member doc read rules:
        // - super_admin/hrd/management can read
        // - member themselves can read
        // - approver for that member can read
        allow get: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isManagement() && !isHrd()) || (isSignedIn() && request.auth.uid == memberId) || (isSignedIn() && resource.data.approvalTargetUid == request.auth.uid);

        allow list: if isSuperAdmin() ||
          (isHrd() && hrdCanReadMission(missionId)) ||
          (isManagement() && !isHrd()) ||
          resource.data.employeeUid == request.auth.uid ||
          resource.data.approvalTargetUid == request.auth.uid;

        // Creation: only mission creator/HRD/Super Admin may create member docs
        allow create: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isSignedIn() && get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedByUid == request.auth.uid);

        // Update rules:
        // - staff can update their own confirmation fields
        // - any confirmed mission member can update tracking fields of fellow members (group milestone)
        // - approver can only update managerValidation related fields
        // - HRD/Super Admin/Management can update any
        allow update: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isManagement() && !isHrd()) || (
          isSignedIn() && (
            // Staff confirmation update (own doc only)
            ((request.auth.uid == resource.data.employeeUid) &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'staffConfirmationStatus', 'staffConfirmationNote', 'updatedAt'
              ]))
            // Trip tracking milestone update — any member of the same mission can update
            // tracking fields on any other member (group departure/arrival/return/issue)
            || (
              (
                (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids is list &&
                 request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids) ||
                (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedStaffUids is list &&
                 request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedStaffUids)
              ) &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'memberTripStatus', 'memberStatus',
                'departedAt', 'actualDepartureAt',
                'arrivedAt',
                'activityDoneAt',
                'returnedAt', 'actualReturnAt',
                'issueNote', 'issueCategory', 'issueUrgency', 'issueAt',
                'lastTripUpdateAt', 'lastTripUpdateByUid', 'lastTripUpdateByName',
                'updatedAt'
              ])
            )
            // Approver manager validation update
            || ((request.auth.uid == resource.data.approvalTargetUid) &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'managerValidationStatus', 'managerValidationNote', 'managerReplacementSuggestion', 'updatedAt'
              ]))
          )
        );

        allow delete: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId));
      }

      // Approval requests subcollection: documents keyed by approver UID
      match /approval_requests/{approverId} {
        allow get: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isManagement() && !isHrd()) || (isSignedIn() && request.auth.uid == approverId);
        allow list: if isSuperAdmin() ||
          (isHrd() && hrdCanReadMission(missionId)) ||
          (isManagement() && !isHrd()) ||
          resource.data.approverUid == request.auth.uid ||
          approverId == request.auth.uid;
        allow create: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isSignedIn() && get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedByUid == request.auth.uid);
        // Only the approver (or HRD/Super Admin) can update their approval request
        allow update: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isSignedIn() && request.auth.uid == approverId);
        allow delete: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId));
      }

      // Timeline: mission-level timeline entries
      match /timeline/{entryId} {
        allow get: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isManagement() && !isHrd()) || (isSignedIn() && (
          resource.data.byUid == request.auth.uid ||
          get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedByUid == request.auth.uid ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedStaffUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedStaffUids) ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids)
        ));
        allow list: if isSuperAdmin() ||
          (isHrd() && hrdCanReadMission(missionId)) ||
          (isManagement() && !isHrd()) ||
          resource.data.byUid == request.auth.uid ||
          get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedByUid == request.auth.uid ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedStaffUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedStaffUids) ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids);
        // Mission members (staff) may create tracking timeline entries
        allow create: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isManagement() && !isHrd()) || (isSignedIn() && (
          get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedByUid == request.auth.uid ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids) ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedStaffUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedStaffUids)
        ));
        allow update, delete: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId));
      }

      // Staff changes subcollection for mission staffing history
      match /staff_changes/{changeId} {
        allow get: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isManagement() && !isHrd()) || (isSignedIn() && (
          get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedByUid == request.auth.uid ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedStaffUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedStaffUids) ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids) ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.approvalTargetUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.approvalTargetUids) ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.managerUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.managerUids)
        ));
        allow list: if isSuperAdmin() ||
          (isHrd() && hrdCanReadMission(missionId)) ||
          (isManagement() && !isHrd()) ||
          get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedByUid == request.auth.uid ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedStaffUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedStaffUids) ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids) ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.approvalTargetUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.approvalTargetUids) ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.managerUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.managerUids);
        allow create: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isManagement() && !isHrd()) || (isSignedIn() && (
          get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedByUid == request.auth.uid ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.approvalTargetUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.approvalTargetUids) ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.managerUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.managerUids)
        ));
        allow update: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isManagement() && !isHrd()) || (isSignedIn() && (
          get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedByUid == request.auth.uid ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.approvalTargetUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.approvalTargetUids) ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.managerUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.managerUids)
        ));
        allow delete: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isManagement() && !isHrd());
      }

      // Final report (team or mixed mode main report)
      match /final_report/{reportId} {
        allow get: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isManagement() && !isHrd()) || (isSignedIn() && (
          get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedByUid == request.auth.uid ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids) ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedStaffUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedStaffUids)
        ));
        allow list: if isSuperAdmin() ||
          (isHrd() && hrdCanReadMission(missionId)) ||
          get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedByUid == request.auth.uid ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids) ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedStaffUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedStaffUids);
        allow create: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isManagement() && !isHrd()) || (isSignedIn() && (
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids) ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedStaffUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedStaffUids) ||
          get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedByUid == request.auth.uid
        ));
        // Staff may update their own team report while draft OR when revision was requested
        allow update: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isManagement() && !isHrd()) ||
          (isSignedIn() && resource.data.dilaporkanOlehUid == request.auth.uid &&
            (resource.data.submittedAt == null || resource.data.reportReviewStatus == "revision_requested"));
        allow delete: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId));
      }

      // Per-member individual reports (individual_report mode)
      match /member_final_reports/{memberUid} {
        allow get: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isManagement() && !isHrd()) || (isSignedIn() && (
          request.auth.uid == memberUid ||
          get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedByUid == request.auth.uid ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids)
        ));
        allow list: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || request.auth.uid == memberUid;
        allow create: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isManagement() && !isHrd()) || (isSignedIn() && request.auth.uid == memberUid);
        // Staff may update their own report while draft OR when revision was requested
        allow update: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isManagement() && !isHrd()) ||
          (isSignedIn() && request.auth.uid == memberUid &&
            (resource.data.submittedAt == null || resource.data.reportReviewStatus == "revision_requested"));
        allow delete: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId));
      }

      // Per-member notes (mixed_report mode optional personal notes)
      match /member_notes/{memberUid} {
        allow get: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isManagement() && !isHrd()) || (isSignedIn() && (
          request.auth.uid == memberUid ||
          get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedByUid == request.auth.uid ||
          (get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids is list && request.auth.uid in get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.memberUids)
        ));
        allow list: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || request.auth.uid == memberUid;
        allow create, update: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isManagement() && !isHrd()) || (isSignedIn() && request.auth.uid == memberUid);
        allow delete: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId));
      }

      // Manager validations cache
      match /manager_validations/{validationId} {
        allow get: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isManagement() && !isHrd()) || (isSignedIn() && (
          resource.data.managerUid == request.auth.uid ||
          get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedByUid == request.auth.uid
        ));
        allow list: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isManagement() && !isHrd());
        allow create, update, delete: if isSuperAdmin() || (isHrd() && hrdCanReadMission(missionId)) || (isSignedIn() && get(/databases/$(database)/documents/business_trip_missions/$(missionId)).data.assignedByUid == request.auth.uid);
      }
    }

    // Legacy business_trips collection for older detail pages and imports
    match /business_trips/{tripId} {
      allow get: if isSuperAdmin() || (isHrd() && hrdCanReadBrandData(resource.data)) || (isManagement() && !isHrd()) ||
        (isSignedIn() && resource.data.assignedByUid == request.auth.uid);
      allow list: if isSuperAdmin() || (isHrd() && hrdCanReadBrandData(resource.data)) || (isManagement() && !isHrd());
      allow create: if isSuperAdmin() || (isHrd() && hrdCanCreateBrandData(request.resource.data)) || (isSignedIn() && request.resource.data.assignedByUid == request.auth.uid);
      allow update: if isSuperAdmin() || (isHrd() && hrdCanUpdateBrandData(resource.data, request.resource.data)) || (isSignedIn() && resource.data.assignedByUid == request.auth.uid);
      allow delete: if isSuperAdmin() || (isHrd() && hrdCanReadBrandData(resource.data));

      match /timeline/{entryId} {
        allow get: if isSuperAdmin() || (isHrd() && hrdCanReadLegacyTrip(tripId)) || (isManagement() && !isHrd()) || (isSignedIn() && (
          resource.data.byUid == request.auth.uid ||
          get(/databases/$(database)/documents/business_trips/$(tripId)).data.assignedByUid == request.auth.uid
        ));
        allow list: if isSuperAdmin() ||
          (isHrd() && hrdCanReadLegacyTrip(tripId)) ||
          (isManagement() && !isHrd()) ||
          resource.data.byUid == request.auth.uid ||
          get(/databases/$(database)/documents/business_trips/$(tripId)).data.assignedByUid == request.auth.uid;
        allow create: if isSuperAdmin() || (isHrd() && hrdCanReadLegacyTrip(tripId)) || (isSignedIn() && get(/databases/$(database)/documents/business_trips/$(tripId)).data.assignedByUid == request.auth.uid);
        allow update, delete: if isSuperAdmin() || (isHrd() && hrdCanReadLegacyTrip(tripId));
      }

      match /expenses/{expenseId} {
        allow get: if isSuperAdmin() || (isHrd() && hrdCanReadLegacyTrip(tripId)) || (isManagement() && !isHrd()) || (isSignedIn() && get(/databases/$(database)/documents/business_trips/$(tripId)).data.assignedByUid == request.auth.uid);
        allow list: if isSuperAdmin() ||
          (isHrd() && hrdCanReadLegacyTrip(tripId)) ||
          (isManagement() && !isHrd()) ||
          get(/databases/$(database)/documents/business_trips/$(tripId)).data.assignedByUid == request.auth.uid;
        allow create: if isSuperAdmin() || (isHrd() && hrdCanReadLegacyTrip(tripId)) || (isSignedIn() && get(/databases/$(database)/documents/business_trips/$(tripId)).data.assignedByUid == request.auth.uid);
        allow update, delete: if isSuperAdmin() || (isHrd() && hrdCanReadLegacyTrip(tripId));
      }
    }

    match /employees/{employeeId} {
      allow get, list: if isSuperAdmin() ||
        (isHrd() && hrdCanReadBrandData(resource.data)) ||
        (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isSuperAdmin() || (isHrd() && hrdCanCreateBrandData(request.resource.data));
      allow update: if isSuperAdmin() || (isHrd() && hrdCanUpdateBrandData(resource.data, request.resource.data));
      allow delete: if isSuperAdmin();
    }

    match /bank_change_requests/{requestId} {
      allow get, list: if isSuperAdmin() ||
        (isHrd() && hrdCanReadBrandData(resource.data)) ||
        (isSignedIn() && resource.data.employeeUid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.employeeUid == request.auth.uid;
      allow update: if isSuperAdmin() || (isHrd() && hrdCanUpdateBrandData(resource.data, request.resource.data));
      allow delete: if isSuperAdmin();
    }

    match /leave_balances/{balanceId} {
      allow get, list: if isSuperAdmin() ||
        (isHrd() && hrdCanReadBrandData(resource.data)) ||
        (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow create: if isSuperAdmin() || (isHrd() && hrdCanCreateBrandData(request.resource.data));
      allow update: if isSuperAdmin() || (isHrd() && hrdCanUpdateBrandData(resource.data, request.resource.data));
      allow delete: if isSuperAdmin();
    }

    match /leave_balance_adjustments/{adjustmentId} {
      allow get, list: if isSuperAdmin() || (isHrd() && hrdCanReadBrandData(resource.data));
      allow create: if isSuperAdmin() || (isHrd() && hrdCanCreateBrandData(request.resource.data));
      allow update: if isSuperAdmin() || (isHrd() && hrdCanUpdateBrandData(resource.data, request.resource.data));
      allow delete: if isSuperAdmin();
    }

    match /company_holidays/{holidayId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    // Landing Page CMS Sections
    // All writes are done via server API with Firebase Admin SDK
    // Client can only read
    match /landing_sections/{sectionId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    /**
     * /system_settings/{docId}
     * - backup_export and session_security are readable by Super Admin only.
     * - google_drive_oauth contains OAuth refresh tokens — NEVER readable from client.
     * - "features" (Feature Control) is public-readable: unauthenticated visitors on
     *   public pages (e.g. /careers/register) need to know if candidate_portal is OFF
     *   before they've signed in.
     * - Other settings (idle timeout, forceLogoutAllAt, menu_visibility) are readable by all signed-in users.
     * - Only Super Admin can write any setting.
     */
    match /system_settings/{docId} {
      allow read: if docId == 'features' || (isSignedIn() && (
        !(docId in ['backup_export']) || isSuperAdmin()
      ) && docId != 'google_drive_oauth');
      allow create, update: if isSuperAdmin() && docId != 'google_drive_oauth';
      allow delete: if false;
    }

    // google_drive_oauth contains sensitive refresh tokens — server-only via Admin SDK
    match /system_settings/google_drive_oauth {
      allow read, write: if false;
    }

    /**
     * /session_logs/{logId}
     * - Any authenticated user can create a log entry for their own session.
     * - Only Super Admin can read or list all logs.
     */
    match /session_logs/{logId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read, list: if isSuperAdmin();
      allow update, delete: if false;
    }

    /**
     * /online_sessions/{userId}
     * - Signed-in users update only their own heartbeat document.
     * - Super Admin can read/list current online users.
     */
    match /online_sessions/{userId} {
      allow read, list: if isSuperAdmin();
      allow create, update: if isSignedIn() && userId == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    /**
     * /system_analytics_events/{eventId}
     * - Signed-in users may create non-sensitive activity events for themselves.
     * - Super Admin can read/list aggregated analytics.
     * - Immutable from the client.
     */
    match /system_analytics_events/{eventId} {
      allow read, list: if isSuperAdmin();
      allow create: if isSignedIn() && (
        !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid ||
        request.resource.data.uid == null
      );
      allow update, delete: if false;
    }

    /**
     * /audit_logs/{logId}
     * - Super Admin can create and read audit logs.
     * - Immutable: no update or delete allowed.
     */
    match /audit_logs/{logId} {
      allow read, list: if isSuperAdmin();
      allow create: if isSignedIn() && isSuperAdmin();
      allow update, delete: if false;
    }

    /**
     * /sync_logs/{logId}
     * - Written ONLY by the Admin SDK from /api/admin/sync/* routes (client create is
     *   always denied) — Sync Center never writes directly to Firestore from the browser.
     * - Super Admin can read for the "Terakhir dijalankan" / "Lihat Riwayat" UI.
     */
    match /sync_logs/{logId} {
      allow read, list: if isSuperAdmin();
      allow create, update, delete: if false;
    }

    /**
     * Storage Management (technical, Super Admin only) — all writes come from
     * /api/admin/storage/* via the Admin SDK (which bypasses these rules
     * entirely). Client-side reads are Super Admin only since this exposes
     * internal file paths/metadata, not HRD data.
     */
    match /storage_file_index/{fileId} {
      allow read, list: if isSuperAdmin();
      allow create, update, delete: if false;
    }

    match /storage_scan_reports/{reportId} {
      allow read, list: if isSuperAdmin();
      allow create, update, delete: if false;
    }

    match /storage_provider_logs/{logId} {
      allow read, list: if isSuperAdmin();
      allow create, update, delete: if false;
    }

    /**
     * /inventory_access/{uid}
     * Grants the separate "inventory_admin" access flag to specific employees
     * — NOT an HRP role change (users/{uid}.role is never touched by this).
     * Only Super Admin may grant/revoke; an employee may read their own doc to
     * check their own access, but cannot list all grants or write to any doc
     * (including their own) — that would let an Inventory Admin re-grant or
     * extend their own access, which must stay Super-Admin-only.
     */
    match /inventory_access/{uid} {
      allow get: if isSuperAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow list: if isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    /**
     * /inventory_access_logs/{logId}
     * Append-only audit trail of grant/revoke actions. Super Admin only.
     */
    match /inventory_access_logs/{logId} {
      allow read, list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update, delete: if false;
    }

    /**
     * /inventory_items/{itemId}
     * Barang perusahaan didata di HRP (canManageInventory = Super Admin or
     * an active inventory_access grant). Any signed-in user can read — the
     * separate Scan Portal app reads the same collection to show item detail
     * when an employee scans its QR code, and to check current
     * status/borrower before allowing a borrow/return.
     */
    match /inventory_items/{itemId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if canManageInventory();
    }

    /**
     * /inventory_borrowings/{borrowingId}
     * Created/updated by canManageInventory() from HRP's Data Peminjaman
     * page, or by the Scan Portal's own server-side (Admin SDK) borrow/return
     * flow — which bypasses these client rules entirely. Any signed-in user
     * can read so an employee can see their own borrowing history.
     */
    match /inventory_borrowings/{borrowingId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if canManageInventory();
    }

    /**
     * /inventory_logs/{logId}
     * Append-only audit trail of inventory item actions (create/update/
     * deactivate/QR generation/borrow/return). Only canManageInventory() may
     * write; immutable once written.
     */
    match /inventory_logs/{logId} {
      allow read, list: if canManageInventory();
      allow create: if canManageInventory();
      allow update, delete: if false;
    }

    /**
     * /inventory_categories/{categoryId}
     * Master data for item categories (Elektronik, Laptop, ...). Managed from
     * HRP's Kategori Barang page. Any signed-in user can read (the Scan
     * Portal may want to show a category label on item detail); only
     * canManageInventory() may create/update/deactivate. Never hard-deleted
     * (deactivate sets status: "inactive"), so delete stays disabled.
     */
    match /inventory_categories/{categoryId} {
      allow read, list: if isSignedIn();
      allow create, update: if canManageInventory();
      allow delete: if false;
    }

    /**
     * /export_logs/{logId}
     * - Super Admin only can create and read export logs.
     * - Immutable: no update or delete allowed.
     */
    match /export_logs/{logId} {
      allow read, list: if isSuperAdmin();
      allow create: if isSignedIn() && isSuperAdmin();
      allow update, delete: if false;
    }

    /**
     * /backup_logs/{logId}
     * - Super Admin only can create and read backup logs.
     * - Immutable.
     */
    match /backup_logs/{logId} {
      allow read, list: if isSuperAdmin();
      allow create: if isSignedIn() && isSuperAdmin();
      allow update, delete: if false;
    }

    /**
     * /data_integrity_reports/{reportId}
     * - Server writes completed Data Integrity reports via Admin SDK.
     * - Super Admin can read/list report history.
     * - Immutable from the client.
     */
    match /data_integrity_reports/{reportId} {
      allow read, list: if isSuperAdmin();
      allow create, update, delete: if false;
    }

    /**
     * /load_test_reports/{reportId}
     * - Super Admin creates reports after running Simulation Lab.
     * - Read-only after creation (no updates/deletes from client).
     */
    match /load_test_reports/{reportId} {
      allow read, list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update, delete: if false;
    }

    /**
     * /backup_progress/{backupId}
     * - Server writes real-time backup progress with Admin SDK.
     * - Super Admin can read progress while the modal is open.
     */
    match /backup_progress/{backupId} {
      allow read, list: if isSuperAdmin();
      allow create, update, delete: if false;
    }

    match /system_announcements/{announcementId} {
      allow read, list: if isSignedIn();
      allow create, update: if isSuperAdmin();
      allow delete: if isSuperAdmin() && (
        resource.data.status == 'draft' ||
        resource.data.status == 'archived' ||
        (resource.data.status == 'active' && resource.data.startAt != null && resource.data.startAt > request.time)
      );
      match /reads/{uid} {
        allow read, list: if isSuperAdmin();
        allow create, update: if isSignedIn() && request.auth.uid == uid;
        allow delete: if false;
      }
    }

    /**
     * /system_maintenance/{ruleId}
     * - Every signed-in user must be able to read the rule set, so the client
     *   guard (AdminGuard / candidate portal layout) can evaluate whether they
     *   are blocked. Only Super Admin may create/update/delete rules.
     */
    match /system_maintenance/{maintenanceId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    /**
     * /system_maintenance_logs/{logId}
     * - Append-only audit trail of maintenance rule changes.
     */
    match /system_maintenance_logs/{logId} {
      allow get, list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update, delete: if false;
    }

    /**
     * /hrd_notifications/{notifId}
     * Per-HRD action-item feed (bank change requests, personality test
     * completed, etc). After splitting HRD into per-brand accounts, an HRD
     * must ONLY ever read notifications addressed to them — never a global
     * list of every HRD's notifications, which is exactly what "resource.data
     * .recipientUid == request.auth.uid" enforces per-document. Super Admin
     * keeps full visibility. Creation happens almost exclusively server-side
     * (Admin SDK, via /api/notifications/hrd-notify, which resolves the
     * correct brand-scoped recipientUid(s) from roles_hrd) — Admin SDK writes
     * bypass these rules entirely, so `allow create: if isSignedIn()` here
     * only covers the handful of legacy client-side callers (overtime/leave
     * review dialogs, candidate application submission) that still write
     * directly; those docs simply won't carry a recipientUid yet.
     */
    match /hrd_notifications/{notifId} {
      allow get, list: if isSuperAdmin() ||
        (isSignedIn() && resource.data.get('recipientUid', null) == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() ||
        (isSignedIn() && resource.data.get('recipientUid', null) == request.auth.uid);
      allow delete: if isSuperAdmin();
    }
  }
}
